{
  "extends": ["@unconfig/ts-config/node.json"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true
  },
  "include": ["./src/*.ts", "./**/typings/**/*", "./**/*.json"],
  "exclude": [
    "**/__tests__/**",
    "**/tests/**",
    "**/dist/**/*",
    "**/node_modules/**/*",
    "**/*.md",
    "./src/node/**/*",
    "./src/web/**/*"
  ]
}
