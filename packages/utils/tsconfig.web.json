{
  "extends": ["@unconfig/ts-config/web.json"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true
  },
  "include": ["./src/web/**/*", "./src/*"],
  "exclude": [
    "**/__tests__/**",
    "**/tests/**",
    "**/dist/**/*",
    "**/node_modules/**/*",
    "**/*.md"
  ]
}
